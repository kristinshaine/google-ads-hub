{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/lsa-report", "dest": "/api/lsa-report.js" },
    { "src": "/api/mcc-accounts", "dest": "/api/mcc-accounts.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
